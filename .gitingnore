@'
# IDE
.idea/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Ambienti virtuali
.venv/
venv/
env/

# Test e tooling
.pytest_cache/
.coverage
htmlcov/

# File locali / segreti
.env

# Log generati localmente, ma mantieni quelli di esempio
*.log
!examples/*.log

# Stato runtime generato dal programma
data/
'@ | Set-Content -Encoding UTF8 .gitignore

git rm -r --cached .idea